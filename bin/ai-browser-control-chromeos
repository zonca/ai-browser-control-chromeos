#!/usr/bin/env bash
set -euo pipefail

token_file="${AI_BROWSER_CONTROL_CHROMEOS_TOKEN_FILE:-$HOME/.config/ai-browser-control-chromeos/extension-token}"
session="${AI_BROWSER_CONTROL_CHROMEOS_SESSION:-chromeos}"
browser="${AI_BROWSER_CONTROL_CHROMEOS_BROWSER:-chrome}"
output_dir="${AI_BROWSER_CONTROL_CHROMEOS_OUTPUT_DIR:-/tmp/ai-browser-control-chromeos-${UID}}"
state_dir="${AI_BROWSER_CONTROL_CHROMEOS_STATE_DIR:-$HOME/.local/state/ai-browser-control-chromeos}"
pid_file="$state_dir/connect-${session}.pid"
log_file="$state_dir/connect-${session}.log"
self="$(readlink -f "$0")"

if [[ ! -r "$token_file" ]]; then
  printf 'Missing browser extension token: %s\nRun the skill setup script first.\n' "$token_file" >&2
  exit 1
fi

playwright_cli="${AI_BROWSER_CONTROL_CHROMEOS_CLI:-$(command -v playwright-cli || true)}"
if [[ -z "$playwright_cli" || ! -x "$playwright_cli" ]]; then
  printf 'playwright-cli is not installed. Run the skill setup script first.\n' >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  printf 'python3 is required to redact secrets from command output.\n' >&2
  exit 1
fi

connect_helper="${AI_BROWSER_CONTROL_CHROMEOS_CONNECT_HELPER:-$(command -v ai-browser-control-chromeos-connect || true)}"
if [[ -z "$connect_helper" || ! -x "$connect_helper" ]]; then
  printf 'ai-browser-control-chromeos-connect is missing. Run the skill setup script first.\n' >&2
  exit 1
fi

token="$(<"$token_file")"
if [[ -z "$token" || "$token" == *$'\n'* ]]; then
  printf 'The browser extension token file is empty or invalid.\n' >&2
  exit 1
fi

umask 077
mkdir -p "$output_dir" "$state_dir"
chmod 700 "$state_dir"
export PLAYWRIGHT_MCP_EXTENSION_TOKEN="$token"
export PLAYWRIGHT_MCP_EXECUTABLE_PATH="$connect_helper"
export PLAYWRIGHT_MCP_OUTPUT_DIR="$output_dir"
export NODE_OPTIONS="--dns-result-order=ipv4first${NODE_OPTIONS:+ $NODE_OPTIONS}"

run_cli() {
  set +e
  "$playwright_cli" "-s=$session" "$@" 2>&1 |
    PLAYWRIGHT_TOKEN_TO_REDACT="$token" python3 -u -c '
import os
import sys
import urllib.parse

token = os.environ["PLAYWRIGHT_TOKEN_TO_REDACT"]
encoded = urllib.parse.quote(token, safe="")
for line in sys.stdin:
    sys.stdout.write(line.replace(token, "[REDACTED]").replace(encoded, "[REDACTED]"))
'
  statuses=("${PIPESTATUS[@]}")
  set -e
  return "${statuses[0]}"
}

session_is_open() {
  local listing
  if ! listing="$(run_cli list 2>/dev/null)"; then
    return 1
  fi
  [[ "$listing" == *"- $session:"* && "$listing" == *"status: open"* ]]
}

supervisor_pid() {
  [[ -r "$pid_file" ]] || return 1
  local pid command_line
  pid="$(<"$pid_file")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  [[ -r "/proc/$pid/cmdline" ]] || return 1
  command_line="$(tr '\0' ' ' <"/proc/$pid/cmdline")"
  [[ "$command_line" == *"ai-browser-control-chromeos __connect-supervisor"* ]] || return 1
  printf '%s\n' "$pid"
}

remove_own_pid_file() {
  [[ -r "$pid_file" ]] || return 0
  [[ "$(<"$pid_file")" == "$$" ]] || return 0
  rm -f "$pid_file"
}

start_background_connection() {
  local persistent=false
  while (($#)); do
    case "$1" in
      --persistent) persistent=true; shift ;;
      *) shift ;;
    esac
  done

  if session_is_open; then
    printf 'Browser session %s is already connected.\n' "$session"
    return 0
  fi

  local pid
  if pid="$(supervisor_pid)"; then
    printf 'Background connection is already running (pid %s).\n' "$pid"
    printf 'Log: %s\n' "$log_file"
    return 0
  fi

  rm -f "$pid_file"
  : >"$log_file"
  nohup "$self" __connect-supervisor --persistent >>"$log_file" 2>&1 </dev/null &
  pid=$!
  printf '%s\n' "$pid" >"$pid_file"

  # Delayed health check: wait 2 seconds and verify the supervisor is still alive
  sleep 2
  if ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$pid_file"
    printf 'Background connection failed to start (process exited after spawn).\n' >&2
    tail -n 20 "$log_file" >&2 || true
    return 1
  fi

  # If --persistent was requested, also verify the handoff page was reached
  if [[ "$persistent" == true ]]; then
    if session_is_open; then
      printf 'Browser session %s is already connected.\n' "$session"
      return 0
    fi
  fi

  printf 'Background connection started (pid %s).\n' "$pid"
  printf 'Log: %s\n' "$log_file"
}

run_supervisor() {
  local persistent_mode=false
  while (($#)); do
    case "$1" in
      --persistent) persistent_mode=true; shift ;;
      *) shift ;;
    esac
  done

  trap remove_own_pid_file EXIT
  run_cli attach "--extension=$browser"
  while session_is_open; do
    sleep 15
  done

  # In persistent mode, auto-restart if the session closes unexpectedly
  if [[ "$persistent_mode" == true ]]; then
    printf 'Session closed; restarting in 3 seconds...\n' >>"$log_file" 2>&1
    sleep 3
    if ! session_is_open; then
      run_cli attach "--extension=$browser"
      while session_is_open; do
        sleep 15
      done
    fi
  fi
}

show_status() {
  if session_is_open; then
    printf 'connected: session %s is open\n' "$session"
    return 0
  fi

  local pid
  if pid="$(supervisor_pid)"; then
    printf 'connecting: background process %s is waiting for Chrome\n' "$pid"
    return 2
  fi

  rm -f "$pid_file"
  printf 'disconnected: no open browser session\n'
  return 1
}

wait_for_connection() {
  local timeout="${1:-180}"
  [[ "$timeout" =~ ^[0-9]+$ ]] || {
    printf 'wait timeout must be a non-negative integer\n' >&2
    return 2
  }

  local started now pid
  started="$(date +%s)"
  while true; do
    if session_is_open; then
      printf 'connected: session %s is open\n' "$session"
      return 0
    fi
    if ! pid="$(supervisor_pid)"; then
      printf 'Background connection stopped before Chrome connected.\n' >&2
      tail -n 20 "$log_file" >&2 || true
      return 1
    fi
    now="$(date +%s)"
    if ((now - started >= timeout)); then
      printf 'Timed out after %s seconds while waiting for Chrome.\n' "$timeout" >&2
      return 124
    fi
    sleep 1
  done
}

show_logs() {
  local lines="${1:-40}"
  [[ "$lines" =~ ^[0-9]+$ ]] || {
    printf 'log line count must be a non-negative integer\n' >&2
    return 2
  }
  [[ -r "$log_file" ]] || {
    printf 'No background connection log exists for session %s.\n' "$session"
    return 1
  }
  tail -n "$lines" "$log_file"
}

disconnect_browser() {
  local pid=""
  pid="$(supervisor_pid || true)"
  if session_is_open; then
    run_cli detach || true
  fi
  if [[ -n "$pid" ]]; then
    kill "$pid" 2>/dev/null || true
  fi
  rm -f "$pid_file"
  printf 'Browser-control session %s stopped.\n' "$session"
}

case "${1:-}" in
  connect)
    shift
    start_background_connection "$@"
    ;;
  status)
    shift
    [[ $# -eq 0 ]] || {
      printf 'status does not accept arguments\n' >&2
      exit 2
    }
    show_status
    ;;
  wait)
    shift
    [[ $# -le 1 ]] || {
      printf 'wait accepts at most one timeout argument\n' >&2
      exit 2
    }
    wait_for_connection "$@"
    ;;
  logs)
    shift
    [[ $# -le 1 ]] || {
      printf 'logs accepts at most one line-count argument\n' >&2
      exit 2
    }
    show_logs "$@"
    ;;
  disconnect)
    shift
    [[ $# -eq 0 ]] || {
      printf 'disconnect does not accept arguments\n' >&2
      exit 2
    }
    disconnect_browser
    ;;
  reconnect)
    shift
    [[ $# -eq 0 ]] || {
      printf 'reconnect does not accept arguments\n' >&2
      exit 2
    }
    disconnect_browser
    sleep 1
    start_background_connection
    ;;
  __connect-supervisor)
    run_supervisor
    ;;
  "")
    printf 'Usage: ai-browser-control-chromeos {connect [--persistent]|status|wait|logs|disconnect|reconnect|<browser-command>}\n' >&2
    exit 2
    ;;
  *)
    run_cli "$@"
    ;;
esac
