#!/usr/bin/env python3
"""Open a ChromeOS-safe handoff page for a Playwright extension relay URL."""

from __future__ import annotations

import html
import http.server
import json
import shutil
import socketserver
import subprocess
import sys
from urllib.parse import urlparse


EXTENSION_ID = "mmlmfjhmonkocbjadbfplnigmagldckm"


def connection_url_from_argv() -> str:
    if len(sys.argv) < 2:
        raise SystemExit("Playwright did not provide an extension connection URL")
    connection_url = sys.argv[-1]
    parsed = urlparse(connection_url)
    if (
        parsed.scheme != "chrome-extension"
        or parsed.netloc != EXTENSION_ID
        or parsed.path != "/connect.html"
    ):
        raise SystemExit("Refusing an unexpected extension connection URL")
    return connection_url


def opener() -> str:
    for candidate in ("garcon-url-handler", "xdg-open"):
        path = shutil.which(candidate)
        if path:
            return path
    raise SystemExit("Neither garcon-url-handler nor xdg-open is available")


def main() -> None:
    connection_url = connection_url_from_argv()
    safe_url = html.escape(connection_url, quote=True)
    page = f"""<!doctype html>
<html lang="en">
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Connect AI agent to Chrome</title>
<style>
body {{ font: 16px system-ui, sans-serif; max-width: 44rem; margin: 4rem auto; padding: 0 1rem; }}
button {{ font: inherit; padding: .75rem 1rem; cursor: pointer; }}
code {{ overflow-wrap: anywhere; }}
</style>
<h1>Connect AI agent to Chrome</h1>
<p>ChromeOS requires the Playwright extension address to be pasted directly into the address bar.</p>
<button id="copy" type="button">Copy Playwright connection address</button>
<p>Then press <strong>Ctrl+L</strong>, <strong>Ctrl+V</strong>, and <strong>Enter</strong>.</p>
<p id="status" role="status"></p>
<noscript>JavaScript is required to copy the address: <code>{safe_url}</code></noscript>
<script>
const connectionUrl = {json.dumps(connection_url)};
document.querySelector('#copy').addEventListener('click', async () => {{
  await navigator.clipboard.writeText(connectionUrl);
  document.querySelector('#status').textContent = 'Copied. Press Ctrl+L, Ctrl+V, and Enter.';
}});
</script>
</html>""".encode("utf-8")

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_GET(self) -> None:  # noqa: N802 - stdlib callback name
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(page)))
            self.end_headers()
            self.wfile.write(page)

        def log_message(self, format: str, *args: object) -> None:
            del format, args

    with socketserver.TCPServer(("127.0.0.1", 0), Handler) as server:
        server.timeout = 120
        port = server.server_address[1]
        subprocess.run(
            [opener(), f"http://localhost:{port}/"],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        server.handle_request()


if __name__ == "__main__":
    main()
