#!/usr/bin/env python3
"""Open a ChromeOS-safe handoff page for the browser-control relay URL."""

from __future__ import annotations

import html
import http.server
import json
import shutil
import socketserver
import subprocess
import sys
import threading
import time
from urllib.parse import urlparse


EXTENSION_ID = "mmlmfjhmonkocbjadbfplnigmagldckm"


def connection_url_from_argv() -> str:
    if len(sys.argv) < 2:
        raise SystemExit("The browser engine did not provide an extension connection URL")
    connection_url = sys.argv[-1]
    parsed = urlparse(connection_url)
    if (
        parsed.scheme != "chrome-extension"
        or parsed.netloc != EXTENSION_ID
        or parsed.path != "/connect.html"
    ):
        raise SystemExit("Refusing an unexpected extension connection URL")
    return connection_url


def opener() -> str:
    for candidate in ("garcon-url-handler", "xdg-open"):
        path = shutil.which(candidate)
        if path:
            return path
    raise SystemExit("Neither garcon-url-handler nor xdg-open is available")


def main() -> None:
    connection_url = connection_url_from_argv()
    safe_url = html.escape(connection_url, quote=True)
    page = f"""<!doctype html>
<html lang="en">
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Connect AI agent to Chrome</title>
<style>
body {{ font: 16px system-ui, sans-serif; max-width: 44rem; margin: 4rem auto; padding: 0 1rem; }}
button {{ font: inherit; padding: .75rem 1rem; cursor: pointer; margin-right: .5rem; }}
button:disabled {{ opacity: .5; cursor: default; }}
code {{ overflow-wrap: anywhere; }}
#countdown {{ font-weight: bold; color: #666; }}
#status {{ margin-top: 1rem; }}
</style>
<h1>Connect AI agent to Chrome</h1>
<p>ChromeOS requires the browser-control extension address to be pasted directly into the address bar.</p>
<button id="copy" type="button">Copy browser connection address</button>
<button id="retry" type="button" style="display:none;">Retry (reopen this page)</button>
<p>Then press <strong>Ctrl+L</strong>, <strong>Ctrl+V</strong>, and <strong>Enter</strong>.</p>
<p id="status" role="status"></p>
<p>Session expires in <span id="countdown">120</span>s</p>
<noscript>JavaScript is required to copy the address: <code>{safe_url}</code></noscript>
<script>
const connectionUrl = {json.dumps(connection_url)};
const timeout = 120;
let secondsLeft = timeout;
const countdownEl = document.querySelector('#countdown');
const statusEl = document.querySelector('#status');
const copyBtn = document.querySelector('#copy');
const retryBtn = document.querySelector('#retry');

const timer = setInterval(() => {{
  secondsLeft--;
  countdownEl.textContent = secondsLeft;
  if (secondsLeft <= 0) {{
    clearInterval(timer);
    copyBtn.disabled = true;
    retryBtn.style.display = 'inline-block';
    statusEl.textContent = 'Session expired. Click Retry to get a new connection address.';
  }}
}}, 1000);

copyBtn.addEventListener('click', async () => {{
  try {{
    await navigator.clipboard.writeText(connectionUrl);
    statusEl.textContent = 'Copied. Press Ctrl+L, Ctrl+V, and Enter in the address bar.';
  }} catch (e) {{
    statusEl.textContent = 'Copy failed. The raw address is: ' + connectionUrl;
  }}
}});

retryBtn.addEventListener('click', () => {{
  window.location.reload();
}});
</script>
</html>""".encode("utf-8")

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_GET(self) -> None:  # noqa: N802 - stdlib callback name
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.send_header("Content-Length", str(len(page)))
            self.end_headers()
            self.wfile.write(page)

        def log_message(self, format: str, *args: object) -> None:
            del format, args

    with socketserver.TCPServer(("127.0.0.1", 0), Handler) as server:
        server.timeout = 180  # extended from 120s to 180s
        port = server.server_address[1]

        def open_browser():
            subprocess.run(
                [opener(), f"http://localhost:{port}/"],
                check=False,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

        # Open browser in a thread so we don't block the server
        threading.Thread(target=open_browser, daemon=True).start()

        # Handle requests until timeout
        while True:
            try:
                server.handle_request()
            except Exception:
                break


if __name__ == "__main__":
    main()